<div class="frame-container" style="position: relative; width: 100%; height: 100vh;">
  <div class="wantedex-container">
    <h2 class="wantedex-title">EDITION</h2>
    <p class="wantedex-subtitle">Modifier la prime - <%= @bounty.name %></p>

    <%= render "form",
          bounty: @bounty,
          form_url: bounty_path(@bounty),
          form_method: :patch,
          legend: "Modifier la prime",
          submit_label: "Enregistrer les modifications" %>

    <div class="mt-3 mb-2 text-center">
      <%= link_to wantedex_path, class: "wantedex-back-btn" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour
      <% end %>
    </div>
  </div>
</div>
