<% viewer_role = current_user.can_manage_wantedex? ? :manager : :chasseur %>
<%= turbo_stream_from "bounties_#{viewer_role}" %>

<div class="frame-container" style="position: relative; width: 100%; height: 100vh;">
  <div class="wantedex-container">
    <h2 class="wantedex-title">WANTEDEX</h2>
    <p class="wantedex-subtitle">Primes - Ch'arsaac</p>

    <% if current_user.can_manage_wantedex? %>
      <%= render "form",
            bounty: @bounty,
            form_url: bounties_path,
            form_method: :post,
            legend: "Nouvelle prime",
            submit_label: "Publier la prime" %>
    <% end %>

    <% if @bounties.any? %>
      <% @bounties.each do |bounty| %>
        <%= render "poster", bounty: bounty, viewer_role: viewer_role %>
      <% end %>
    <% else %>
      <p class="wantedex-empty">Aucune prime active.</p>
    <% end %>

    <div class="mt-3 mb-2 text-center">
      <%= link_to root_path, class: "wantedex-back-btn" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour
      <% end %>
    </div>
  </div>
</div>
