<div class="frame-container" style="position: relative; width: 100%; height: 100vh;">
  <!-- Username -->
  <p class="username-display mt-1 text-primary fw-bold">
    <%= current_user.username.titleize %>
  </p>

  <!-- Cadre principal SVG -->
  <img src="<%= asset_path('cadre2.svg') %>" alt="Cadre" class="ui-frame">

  <div class="repair-scan-container">
    <h2 class="repair-title"><i class="fa-solid fa-wrench"></i> Reparations</h2>

    <div class="scan-instructions mt-3">
      <div class="text-center mb-3">
        <i class="fa-solid fa-qrcode" style="font-size: 3rem; color: #1EDD88;"></i>
      </div>
      <p class="text-light text-center" style="font-size: 0.9rem;">
        Scannez le QR Code de l'equipement avec <strong>l'appareil photo</strong> de votre telephone.
        Le lien s'ouvrira automatiquement dans l'application.
      </p>
    </div>

    <hr class="border-success opacity-50">

    <!-- Saisie manuelle du token -->
    <div class="manual-entry mt-3">
      <p class="text-muted text-center" style="font-size: 0.8rem;">
        <i class="fa-solid fa-keyboard"></i> Ou entrez le code manuellement :
      </p>
      <div class="d-flex gap-2 justify-content-center">
        <input type="text" class="form-control form-control-sm" style="max-width: 200px;"
               placeholder="Code QR" data-repair-scanner-target="manualInput"
               data-controller="repair-scanner">
        <button class="btn btn-sm btn-outline-success" data-action="click->repair-scanner#manualSubmit">
          <i class="fa-solid fa-arrow-right"></i>
        </button>
      </div>
    </div>

    <div class="mt-3">
      <%= link_to root_path, class: "btn btn-sm btn-outline-success" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour
      <% end %>
    </div>
  </div>
</div>
