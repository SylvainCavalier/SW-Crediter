<div class="frame-container" style="position: relative; width: 100%; height: 100vh;" data-controller="repair"
     data-repair-validate-url-value="<%= repair_validate_path(@repair.qr_token) %>"
     data-repair-home-url-value="<%= root_path %>">
  <!-- Username -->
  <p class="username-display mt-1 text-primary fw-bold">
    <%= current_user.display_username %>
  </p>

  <!-- Contenu principal de reparation -->
  <div class="repair-page-container" data-repair-target="mainContent">
    <h2 class="repair-title"><i class="fa-solid fa-screwdriver-wrench"></i> Reparation</h2>

    <div class="repair-object-card">
      <h3 class="repair-object-name"><%= @repair.name %></h3>
      <% if @repair.description.present? %>
        <p class="repair-object-desc"><%= @repair.description %></p>
      <% end %>
    </div>

    <% if @already_repaired %>
      <div class="repair-already-done">
        <i class="fa-solid fa-circle-check"></i>
        <p>Cet equipement a deja ete repare par vos soins.</p>
        <%= link_to repairs_scan_path, class: "btn btn-outline-success mt-2" do %>
          <i class="fa-solid fa-arrow-left"></i> Retour
        <% end %>
      </div>
    <% else %>
      <!-- Liste des pieces requises -->
      <% if @repair.required_parts.present? %>
        <div class="repair-parts-section">
          <h4><i class="fa-solid fa-puzzle-piece"></i> Composants requis</h4>
          <ul class="repair-parts-list">
            <% @repair.required_parts.each do |part| %>
              <li>
                <i class="fa-solid fa-gear"></i>
                <span><%= part %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Saisie du code -->
      <div class="repair-code-section">
        <h4><i class="fa-solid fa-key"></i> Code d'assemblage</h4>
        <p class="repair-code-hint">Entrez le code trouve sur les composants reunis</p>
        <div class="repair-code-input-group">
          <input type="text" class="form-control repair-code-input"
                 placeholder="Code..." data-repair-target="codeInput"
                 data-action="keydown.enter->repair#submitCode">
          <button class="btn btn-success repair-submit-btn" data-action="click->repair#submitCode">
            <i class="fa-solid fa-check"></i> Valider
          </button>
        </div>
        <p class="repair-error" data-repair-target="error"></p>
      </div>

      <div class="mt-2">
        <%= link_to repairs_scan_path, class: "btn btn-sm btn-outline-success" do %>
          <i class="fa-solid fa-arrow-left"></i> Retour
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Ecran de chargement futuriste -->
  <div class="repair-loading-overlay" data-repair-target="loadingOverlay" style="display: none;">
    <div class="repair-loading-content">
      <div class="repair-hologram">
        <div class="repair-hologram-ring ring-1"></div>
        <div class="repair-hologram-ring ring-2"></div>
        <div class="repair-hologram-ring ring-3"></div>
        <div class="repair-hologram-core">
          <i class="fa-solid fa-wrench"></i>
        </div>
      </div>
      <div class="repair-loading-text" data-repair-target="loadingText">
        INITIALISATION DU PROTOCOLE DE REPARATION...
      </div>
      <div class="repair-progress-bar">
        <div class="repair-progress-fill" data-repair-target="progressBar"></div>
      </div>
      <div class="repair-loading-details" data-repair-target="loadingDetails">
        Connexion au systeme GERVATEX...
      </div>
    </div>
  </div>

  <!-- Ecran de confirmation -->
  <div class="repair-success-overlay" data-repair-target="successOverlay" style="display: none;">
    <div class="repair-success-content">
      <div class="repair-success-icon">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h2 class="repair-success-title">REPARATION TERMINEE</h2>
      <div class="repair-success-message">
        <div class="gervatex-logo">GERVATEX</div>
        <p>Le conglomerat GERVATEX est satisfait de vos services.</p>
        <div class="repair-credits-reward">
          <span class="credits-amount">+<%= @repair.reward_credits %></span>
          <span class="credits-label">CREDITS</span>
        </div>
        <p class="credits-info">credites sur votre compte</p>
      </div>
      <a href="<%= root_path %>" class="btn btn-success mt-3">
        <i class="fa-solid fa-arrow-left"></i> Retour a l'accueil
      </a>
    </div>
  </div>
</div>
