<div class="devise-login-container">
  <div class="devise-login-hologram-effect"></div>

  <div class="devise-login-panel">
    <div class="devise-login-logo-container">
      <%= image_tag 'de6.png', class: 'devise-login-logo', alt: 'SW-Crediter' %>
      <div class="devise-login-title-group">
        <h1 class="devise-login-title">Connexion</h1>
        <p class="devise-login-subtitle">Système d'authentification</p>
      </div>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: 'devise-login-form' }) do |f| %>
      <div class="form-inputs">
        <%= f.input :username,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "username", placeholder: "Entrez votre identifiant" },
                    label: "Identifiant" %>

        <%= f.input :password,
                    required: true,
                    input_html: { autocomplete: "current-password", placeholder: "••••••••" },
                    label: "Mot de passe" %>

        <% if devise_mapping.rememberable? %>
          <%= f.input :remember_me, as: :boolean, label: "Rester connecté" %>
        <% end %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Accéder au système", class: 'devise-login-btn' %>
      </div>
    <% end %>

    <div class="devise-login-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
