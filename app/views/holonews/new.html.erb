<div class="frame-container" style="position: relative; width: 100%; height: 100vh;">
  <!-- Username -->
  <p class="username-display mt-1 text-primary fw-bold">
    <%= current_user.display_username %>
  </p>

  <!-- Cadre principal SVG -->
  <img src="<%= asset_path('cadre2.svg') %>" alt="Cadre" class="ui-frame">
  <!-- Formulaire -->
  <div class="custom-form">
    <%= simple_form_for @holonew, local: true do |f| %>
      <% if @reply_to_id.present? %>
        <%= hidden_field_tag :reply_to, @reply_to_id %>
        <div class="alert alert-info">
          Réponse à <%= @reply_display_label %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.input :title, label: "Titre", input_html: { class: 'form-control' } %>
      </div>

      <% if current_user.pnj? %>
        <% if @sender_npc_options&.any? %>
          <div class="form-group">
            <label>Envoyer en tant que</label>
            <%= select_tag 'sender_npc_character_id',
                options_from_collection_for_select(@sender_npc_options, 'id', 'name'),
                prompt: "Mon prénom réel (#{current_user.real_first_name || current_user.display_username})",
                class: 'form-control' %>
          </div>
        <% end %>
        <div class="form-group">
          <%= f.input :sender_alias,
              label: "Alias d'expéditeur (optionnel)",
              placeholder: "Laissez vide pour utiliser votre nom",
              input_html: { class: 'form-control' } %>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.input :content, label: "Contenu", input_html: { class: 'form-control' } %>
      </div>

      <div class="form-group">
        <%= f.input :image, as: :file, label: "Image (max 5MB)", input_html: { class: 'form-control', accept: 'image/*' } %>
      </div>

      <!-- Sélection du destinataire -->
      <div class="form-group">
        <% if current_user.pj? %>
          <label>Envoyer à :</label>
          <%= select_tag 'recipient',
              grouped_options_for_select(@recipient_options, @reply_recipient_value),
              { prompt: "Sélectionner un contact", class: "form-control" } %>
          <small class="text-muted">Vous ne pouvez envoyer qu'à vos contacts ou aux services. Ajoutez-en en cliquant sur "Mes Contacts".</small>
          <div class="mb-2">
            <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#contactsModal">
              📇 Mes Contacts
            </button>
          </div>
        <% else %>
          <label>Envoyer à :</label>
          <%= select_tag 'recipient',
              grouped_options_for_select(@recipient_options, @reply_recipient_value) +
                "<optgroup label='Diffusion'><option value='all'>Tous</option></optgroup>".html_safe,
              { prompt: "Sélectionner un destinataire", class: "form-control" } %>
        <% end %>
      </div>

      <div class="form-group mt-4">
        <%= link_to "Annuler", holonews_path, class: "btn btn-outline-success" %>
        <%= f.submit "Envoyer", class: "btn btn-outline-success" %>
        <% if current_user.pnj? %>
          <%= f.submit "Ajouter aux brouillons", name: "save_as_draft", class: "btn btn-outline-warning" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Modale Contacts -->
<% if current_user.pj? %>
  <div class="modal fade" id="contactsModal" tabindex="-1" aria-labelledby="contactsModalLabel" aria-hidden="true" data-controller="contacts">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="contactsModalLabel">Mes Contacts</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <!-- Formulaire pour ajouter un contact -->
          <div class="mb-3">
            <%= render "contacts/add_form" %>
            <div id="contact-error" class="mt-2"></div>
          </div>

          <!-- Liste des contacts -->
          <div id="contacts-list">
            <%= render "contacts/list", contacts: current_user.contacts_list %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
        </div>
      </div>
    </div>
  </div>
<% end %>
