<div class="container-fluid mt-4">

  <!-- Boutons en haut à droite (visibles uniquement pour le propriétaire du profil) -->
  <% if @user == current_user %>
    <div class="d-flex justify-content-end mb-3">
      <%= link_to settings_user_path(@user), class: "btn btn-outline-success" do %>
        <i class="fa-solid fa-gears"></i> Réglages
      <% end %>
    </div>
  <% end %>

  <!-- Avatar -->
  <div class="text-center mb-4">
    <div class="avatar-label">
      <% if @user.avatar.attached? %>
        <%= image_tag(@user.avatar, class: "avatar-preview") %>
      <% else %>
        <div class="avatar-placeholder"></div>
      <% end %>
    </div>
  </div>

  <!-- Titre -->
  <h1 class="text-success text-center mb-4">Profil de <%= @user.display_username %></h1>

  <!-- Section Inventaire -->
  <% if @inventory_items.any? %>
    <section class="mb-5">
      <h2 class="text-success text-center mb-4">Inventaire</h2>
      <div class="accordion" id="inventoryAccordion">
        <% @inventory_items.group_by { |item| item.inventory_object.category }.each_with_index do |(category, items), index| %>
          <div class="accordion-item">
            <h2 class="accordion-header" id="heading<%= index %>">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>" aria-expanded="false" aria-controls="collapse<%= index %>">
                <%= category.capitalize %>
              </button>
            </h2>
            <div id="collapse<%= index %>" class="accordion-collapse collapse" aria-labelledby="heading<%= index %>" data-bs-parent="#inventoryAccordion">
              <div class="accordion-body">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Nom</th>
                      <th>Qté</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% items.each do |item| %>
                      <% next if item.quantity <= 0 %>
                      <tr>
                        <td><%= item.inventory_object.name %></td>
                        <td><%= item.quantity %></td>
                        <td style="font-size: 0.8rem;"><%= item.inventory_object.description %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <%= link_to "Retour", root_path, class: "btn btn-outline-secondary" %>
</div>
