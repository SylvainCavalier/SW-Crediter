<div class="frame-container" style="position: relative; width: 100%; height: 100vh;">
  <p class="username-display mt-1 text-primary fw-bold">
    <%= current_user.username.titleize %>
  </p>
  <img src="<%= asset_path('cadre2.svg') %>" alt="Cadre" class="ui-frame">

  <div class="content-container row" style="margin: 10vw;">
    <div class="col-12">
      <div class="text-center m-2">
        <h5 class="text-warning mb-3"><i class="fa-solid fa-landmark-dome"></i> Subventions de la République</h5>

        <p class="text-info" style="font-size: 0.9rem;">
          Souhaitez-vous demander des subventions supplémentaires de la République Galactique
          pour mener à bien votre mission ?
        </p>

        <p class="text-secondary" style="font-size: 0.75rem;">
          La procédure est simple et rapide. Remplissez votre demande ci-dessous.
        </p>

        <%= form_tag subsidy_form_path, method: :get do %>
          <div class="form-group text-success mt-3">
            <label for="amount">Somme demandée (en crédits)</label>
            <input type="number" name="amount" id="amount" class="form-control" min="1" value="100" />
          </div>

          <div class="mt-3">
            <button type="submit" class="btn btn-outline-warning">Soumettre la demande</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%= link_to "Retour", new_transaction_path, class: "btn btn-outline-secondary go-back" %>
</div>
