<div class="content-container" data-controller="lobby-presence">
  <%= turbo_stream_from "user_#{current_user.id}" %>
  <turbo-frame id="pazaak_redirect"></turbo-frame>
  <h2 class="audiowide-regular">Lobby Pazaak</h2>
  <p id="lobby-status">En attente d'autres joueurs…</p>
  <% if @pending_outgoing %>
    <div class="alert alert-info d-inline-flex align-items-center gap-3 m-3">
      <span>Invitation envoyée à <strong><%= @pending_outgoing.invitee.display_username %></strong>, en attente de sa réponse…</span>
      <%= button_to "Annuler", pazaak_invitation_path(@pending_outgoing, decision: :cancel), method: :patch, class: "btn btn-sm btn-outline-danger" %>
    </div>
  <% end %>
  <div id="pazaak_lobby_players">
    <%= render partial: "pazaak/lobbies/players", locals: { players: [] , self_id: current_user.id } %>
  </div>
  <div class="mt-3">
    <%= link_to "Retour", pazaak_menu_path, class: "btn btn-outline-light" %>
  </div>
</div>


