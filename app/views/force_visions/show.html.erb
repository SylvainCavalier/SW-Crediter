<div class="frame-container" style="position: relative; width: 100%; height: 100vh;">
  <p class="username-display mt-1 text-primary fw-bold">
    <%= current_user.display_username %>
  </p>

  <div class="repair-scan-container" data-controller="force-vision-player">
    <h2 class="repair-title"><i class="fa-solid fa-eye"></i> <%= @force_vision.name %></h2>

    <div class="mt-3">
      <video class="w-100" style="max-width: 480px; margin: 0 auto; display: block; border-radius: 8px;"
             playsinline controls autoplay muted
             data-force-vision-player-target="video"
             src="<%= rails_blob_url(@force_vision.video) %>"></video>
    </div>

    <div class="mt-3 text-center">
      <%= link_to force_visions_scan_path, class: "btn btn-sm btn-outline-success" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour
      <% end %>
    </div>
  </div>
</div>
