<div class="frame-container" style="position: relative; width: 100%; height: 100vh; overflow-y: auto;">
  <p class="username-display mt-1 text-primary fw-bold">
    <%= current_user.username.titleize %>
  </p>

  <div class="repair-scan-container">
    <h2 class="repair-title"><i class="fa-solid fa-eye"></i> Visions de la Force</h2>

    <%= form_with(model: @force_vision, url: force_visions_path, local: true,
                  html: { multipart: true, data: { direct_upload_url: rails_direct_uploads_path } }) do |form| %>
      <% if @force_vision.errors.any? %>
        <div class="text-danger small mb-2">
          <%= @force_vision.errors.full_messages.join(", ") %>
        </div>
      <% end %>

      <div class="mb-2">
        <%= form.text_field :name, placeholder: "Nom de la vision", class: "form-control form-control-sm", required: true %>
      </div>
      <div class="mb-2">
        <%= form.file_field :video, accept: "video/*", class: "form-control form-control-sm", direct_upload: true, required: true %>
      </div>
      <%= form.submit "Ajouter", class: "btn btn-sm btn-outline-success w-100" %>
    <% end %>

    <hr class="border-success opacity-50">

    <% if @force_visions.any? %>
      <% @force_visions.each do |vision| %>
        <% if vision.video.attached? %>
          <% vision_url = url_for(controller: "force_visions", action: "show", qr_token: vision.qr_token, only_path: false) %>
          <div class="d-flex align-items-center gap-2 mb-2 p-2"
               style="border: 1px solid rgba(30,221,136,0.3); border-radius: 6px;"
               data-controller="clipboard">
            <div class="flex-grow-1" style="min-width: 0;">
              <div class="text-primary fw-bold" style="font-size: 0.85rem;"><%= vision.name %></div>
              <input type="text" readonly value="<%= vision_url %>"
                     class="form-control form-control-sm"
                     style="font-size: 0.7rem;"
                     data-clipboard-target="source">
            </div>
            <button class="btn btn-sm btn-outline-success"
                    data-clipboard-target="button"
                    data-action="click->clipboard#copy"
                    title="Copier le lien">
              <i class="fa-solid fa-copy"></i>
            </button>
            <%= button_to force_vision_admin_path(vision), method: :delete,
                          data: { turbo_confirm: "Supprimer cette vision ?" },
                          class: "btn btn-sm btn-outline-danger",
                          form: { style: "margin: 0;" } do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-light text-center mt-3" style="font-size: 0.85rem;">Aucune vision pour le moment.</p>
    <% end %>

    <div class="mt-3 text-center">
      <%= link_to force_visions_scan_path, class: "btn btn-sm btn-outline-success" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour au scanner
      <% end %>
    </div>
  </div>
</div>
